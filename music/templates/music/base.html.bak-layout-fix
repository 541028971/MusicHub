    <script>
        // SPA state management
        let initialViewContent = null;
        const appHistory = [];

        function getCurrentState() {
            const mainContent = document.querySelector('.main-scrollable-area');
            const playlistView = mainContent.querySelector('.playlist-detail-container');
            if (playlistView) {
                return { type: 'playlist', id: playlistView.dataset.playlistId };
            }
            return { type: 'featured' };
        }

        function appNavigateTo(page, data, pushHistory = true) {
            const mainContent = document.querySelector('.main-scrollable-area');
            if (!initialViewContent) initialViewContent = mainContent.innerHTML;

            if (pushHistory) {
                const currentState = getCurrentState();
                if (currentState.type !== page || (page === 'playlist' && currentState.id !== data.id)) {
                    appHistory.push(currentState);
                }
            }

            if (page === 'featured') {
                if (window.location.pathname === '/' || window.location.pathname === '') {
                    mainContent.innerHTML = initialViewContent;
                } else {
                    window.location.href = "{% url 'music:index' %}";
                    return;
                }
            } else if (page === 'playlist') {
                renderPlaylistDetailView(data.id);
            }

            // Update UI
            updateSidebarActive(page, data);
            mainContent.scrollTop = 0;
        }

        function updateSidebarActive(page, data) {
            document.querySelectorAll('.sidebar-pill').forEach(elp => elp.classList.remove('active'));
            if (page === 'featured') {
                const featured = document.querySelector('nav .sidebar-pill[onclick*="featured"]');
                if (featured) featured.classList.add('active');
            } else if (page === 'playlist' && data && data.id) {
                // First check fixed pills (favorites, recent) by onclick attribute
                const fixedSelector = `nav .sidebar-pill[onclick*="'${data.id}'"]`;
                const fixedLink = document.querySelector(fixedSelector);
                if (fixedLink) {
                    fixedLink.classList.add('active');
                } else {
                    // Then check dynamic playlist links by data attribute
                    const dynLink = document.querySelector(`#sidebar-playlists .sidebar-pill[data-playlist-id="${data.id}"]`);
                    if (dynLink) dynLink.classList.add('active');
                }
            }
        }

